// ===============================================================
// 飒露紫石 - 紫蓝渐变风格样式
// 配色：紫色、蓝色渐变 + 宣纸黄
// ===============================================================

// 色彩定义
$purple-primary = #8B5CF6
$purple-dark = #6D28D9
$blue-primary = #3B82F6
$blue-dark = #1E40AF
$nav-deep-blue = #1E3A8A
$ink-black = #1F2937
$paper-yellow = #F5F0E1
$cinnabar-red = #C9372C
$ink-gray = #4B5563
$old-paper = #F9F7F2

// 全局背景
body {
  background-color: $old-paper;
  font-family: 'Noto Serif SC', 'Source Han Serif SC', 'SimSun', 'STSong', serif;
}

h1, h2, h3, h4, h5, h6 {
  font-family: 'Noto Serif SC', 'Source Han Serif SC', 'SimHei', serif;
  font-weight: 600;
  color: $ink-black;
}

// ===============================================================
// 头部导航
// ===============================================================
.header {
  background: linear-gradient(135deg, #8B5CF6 0%, #3B82F6 50%, #06B6D4 100%);
  border-bottom: none;
  box-shadow: 0 4px 20px rgba(139, 92, 246, 0.3);
}

.header .site-nav,
.header .site-meta,
.header-inner {
  background: transparent !important;
}

// 品牌容器：隐藏顶部标题区（与侧边栏重复），保留导航切换和搜索按钮
.site-brand-container {
  background: linear-gradient(135deg, #8B5CF6 0%, #3B82F6 100%) !important;

  .site-meta {
    display: none !important;
  }
}

.site-title {
  font-size: 2.4em;
  font-weight: 700;
  letter-spacing: 0.3em;
  color: #FFFFFF !important;
  text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
  padding: 10px 25px;
  border: 2px solid rgba(255,255,255,0.5);
  border-radius: 12px;
  background: rgba(255,255,255,0.2);
  display: inline-block;
  transition: all 0.3s ease;

  &:hover {
    background: rgba(255,255,255,0.35);
    border-color: rgba(255,255,255,0.8);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.3);
  }
}

.site-subtitle {
  font-size: 1em;
  color: rgba(255,255,255,0.9);
  letter-spacing: 0.15em;
  font-style: italic;
  margin-top: 8px;
  text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
}

.brand {
  background: transparent;
  padding: 15px 0;
}

// ===============================================================
// 菜单样式 - 顶部导航
// ===============================================================
.header .menu {
  padding: 8px 0;

  .menu-item {
    margin: 0 0 8px 0 !important;

    a {
      color: $nav-deep-blue !important;
      font-size: 0.95em;
      letter-spacing: 0.05em;
      transition: all 0.3s ease;
      border: 1px solid rgba(30, 58, 138, 0.25) !important;
      border-bottom: 1px solid rgba(30, 58, 138, 0.25) !important;
      border-radius: 8px;
      padding: 8px 15px;
      font-weight: 500;
      background: rgba(219, 234, 254, 0.55);

      &:hover {
        color: $nav-deep-blue !important;
        border-color: rgba(30, 58, 138, 0.45) !important;
        background: rgba(219, 234, 254, 0.85) !important;
        box-shadow: 0 4px 12px rgba(30, 58, 138, 0.12);
        transform: translateX(2px);
      }

      i {
        color: $nav-deep-blue !important;
      }
    }

    &.menu-item-active a {
      color: $nav-deep-blue !important;
      border-color: rgba(30, 58, 138, 0.55) !important;
      font-weight: 600;
      background: rgba(30, 58, 138, 0.18) !important;
      box-shadow: inset 4px 0 0 $nav-deep-blue;

      i {
        color: $nav-deep-blue !important;
      }
    }

    a:focus-visible,
    a:active {
      color: $nav-deep-blue !important;
      border-color: rgba(30, 58, 138, 0.55) !important;
      background: rgba(30, 58, 138, 0.18) !important;
      box-shadow: inset 4px 0 0 $nav-deep-blue;
      outline: none;
    }
  }
}

.header .site-nav {
  background: transparent !important;
}

@media (min-width: 992px) {
  .column {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 12px;
    width: 512px !important;
  }

  .column > .sidebar {
    order: 1;
    width: 332px;
    flex: 0 0 332px;
    position: static !important;
    top: auto !important;
  }

  .column > .sidebar .sidebar-inner {
    max-height: none !important;
    overflow: visible !important;
  }

  .column > .header {
    order: 2;
    width: 168px;
    flex: 0 0 168px;
    margin-top: 0;
    background: transparent !important;
    box-shadow: none !important;
    align-self: flex-start;
  }

  .column > .header .site-brand-container {
    display: none !important;
  }

  .main-inner {
    width: calc(100% - 524px) !important;
  }

  .footer-inner {
    padding-left: 524px !important;
  }
}

// 移动端：菜单展开时使用浅底深字，避免白底白字
@media (max-width: 991px) {
  .header .site-nav {
    background: rgba(245, 240, 225, 0.96) !important;
    border-top: 1px solid rgba(139, 69, 19, 0.15);
  }

  .header .menu .menu-item a {
    color: $nav-deep-blue !important;
    background: transparent !important;
    border-color: rgba(139, 69, 19, 0.15) !important;
    text-shadow: none !important;

    i {
      color: $nav-deep-blue !important;
    }
  }

  .header .menu .menu-item a:hover,
  .header .menu .menu-item.menu-item-active a {
    color: $nav-deep-blue !important;
    background: rgba(59, 130, 246, 0.14) !important;
    border-color: rgba(59, 130, 246, 0.35) !important;
  }
}

// ===============================================================
// 侧边栏样式 - 重要修复
// ===============================================================
.sidebar {
  background: linear-gradient(180deg, #F5F0E1 0%, #EDE4D3 100%) !important;
  border-right: 1px solid rgba(139, 69, 19, 0.15) !important;
  color: $ink-black !important;

  // 覆盖 Pisces @media(min-width:992px) 的 visibility:hidden + 白色背景
  .sidebar-inner {
    --content-bg-color: transparent;
    background: transparent !important;
    box-shadow: none !important;
    visibility: visible !important;
    margin-top: 0 !important;
    padding: 0 !important;
    color: $ink-black !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: flex-start !important;
    align-items: stretch !important;
  }

  // 第二个 sidebar-inner (blogroll) 也去白
  .sidebar-inner.sidebar-blogroll {
    background: transparent !important;
    box-shadow: none !important;
    padding: 10px 20px !important;
    margin-top: 0 !important;
  }

  // 面板容器：用 order:-1 把作者卡片移到功能栏上方
  .sidebar-panel-container {
    order: 1 !important;
    background: transparent !important;
    flex: none !important;
  }

  // 侧边栏标题区域 - 作者头像区块用紫蓝渐变背景
  .site-overview-wrap {
    .site-author {
      background: linear-gradient(135deg, #8B5CF6 0%, #3B82F6 100%);
      margin: 0;
      padding: 30px 20px;
      text-align: center;
      border-radius: 0;

      .site-author-name {
        color: #FFFFFF !important;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
      }

      .site-description {
        color: rgba(255,255,255,0.9) !important;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
      }
    }
  }

  // 侧边栏导航 - 功能栏（文章目录/站点概览）
  // 基础主题设 height:0; visibility:hidden; overflow:hidden，必须全部覆盖
  .sidebar-nav {
    order: 2 !important;
    height: auto !important;
    visibility: visible !important;
    overflow: visible !important;
    pointer-events: auto !important;
    background: rgba(139, 69, 19, 0.08);
    border-bottom: 1px solid rgba(139, 69, 19, 0.12);
    padding: 6px 10px !important;
    margin: 0;

    li {
      color: $ink-black !important;
      padding: 8px 10px;
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.3s ease;
      background: transparent;

      // 悬停时显示紫蓝渐变背景
      &:hover {
        color: #FFFFFF !important;
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.85) 0%, rgba(59, 130, 246, 0.85) 100%) !important;
      }
    }
  }

  // 选中的导航项用紫蓝渐变（根据父级 .sidebar-overview-active / .sidebar-toc-active 判断）
  .sidebar-overview-active .sidebar-nav .sidebar-nav-overview,
  .sidebar-toc-active .sidebar-nav .sidebar-nav-toc {
    color: $ink-black !important;
    background: rgba(139, 92, 246, 0.20) !important;
    border: 1px solid rgba(139, 92, 246, 0.35);
    font-weight: 600;
  }

  // 导航展开态额外样式
  .sidebar-nav-active .sidebar-nav {
    background: rgba(139, 69, 19, 0.12) !important;
    border-radius: 10px;
    border: 1px solid rgba(139, 69, 19, 0.15);
    padding: 8px 10px !important;
    margin: 10px 15px;
  }

  // TOC面板：在非文章页/无TOC时不占空间
  .post-toc-wrap {
    display: none !important;
  }
  // 仅在TOC激活时显示
  .sidebar-toc-active .post-toc-wrap {
    display: block !important;
  }

  .sidebar-panel,
  .post-toc-wrap {
    background: transparent !important;
  }

  // 站点概览面板内部各区块加内边距
  .site-overview-wrap {
    .site-state-wrap,
    .links-of-author,
    .cc-license {
      padding: 0 20px;
    }
  }

  // 侧边栏链接 - 强制覆盖深色主题
  a {
    color: $purple-primary !important;
    border-bottom-color: rgba(139, 92, 246, 0.3) !important;

    &:hover {
      color: $cinnabar-red !important;
      border-bottom-color: $cinnabar-red !important;
    }
  }

  // 侧边栏面板标题
  .sidebar-panel-title {
    font-size: 1em;
    font-weight: 600;
    color: $ink-black !important;
    border-bottom: 2px solid $purple-primary;
    padding-bottom: 8px;
    margin-bottom: 12px;
  }
}

// 强制覆盖所有 .sidebar-inner 白色背景（Pisces 在 @media(min-width:992px) 用 var(--content-bg-color)）
.sidebar .sidebar-inner {
  --content-bg-color: transparent !important;
  background: transparent !important;
  box-shadow: none !important;
}

// 副标题不换行（正确选择器：.site-brand-container，Pisces中位于header内）
.site-brand-container .site-subtitle,
.site-subtitle {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

// 移动端侧边栏覆盖
@media (max-width: 991px) {
  .sidebar {
    background: linear-gradient(180deg, #F5F0E1 0%, #EDE4D3 100%) !important;
    box-shadow: inset 0 2px 6px rgba(0,0,0,0.1) !important;
  }

  .sidebar a {
    color: $purple-primary !important;
    border-bottom-color: rgba(139, 92, 246, 0.3) !important;
  }

  .sidebar a:hover {
    color: $cinnabar-red !important;
    border-bottom-color: $cinnabar-red !important;
  }
}

// ===============================================================
// 侧边栏站点状态
// ===============================================================
.site-state {
  display: flex;
  justify-content: center;
  padding: 15px 0;
  border-top: 1px solid rgba(139, 69, 19, 0.1);
  border-bottom: 1px solid rgba(139, 69, 19, 0.1);
  margin-bottom: 20px;

  .site-state-item {
    padding: 0 15px;
    border-left: 1px solid rgba(139, 69, 19, 0.1);
    text-align: center;

    &:first-child {
      border-left: none;
    }

    a {
      text-decoration: none;
    }

    .site-state-item-count {
      display: block;
      font-size: 1.2em;
      font-weight: 600;
      color: $purple-primary !important;
    }

    .site-state-item-name {
      font-size: 0.8em;
      color: $ink-gray !important;
    }
  }
}

// ===============================================================
// 紫色圆形头像
// ===============================================================
.site-author-image {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B5CF6 0%, #3B82F6 100%);
  border: 4px solid white;
  box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3), 0 0 0 4px rgba(139, 92, 246, 0.1);
  transition: all 0.4s ease;

  &:hover {
    transform: scale(1.1) rotate(5deg);
    box-shadow: 0 8px 25px rgba(139, 92, 246, 0.4), 0 0 0 6px rgba(139, 92, 246, 0.2);
  }
}

.site-author {
  text-align: center;
  padding: 20px 0;
}

.site-author-name {
  color: $ink-black !important;
  font-weight: 600;
  letter-spacing: 0.15em;
  font-size: 1.2em;
  margin-top: 15px;
}

.site-description {
  color: $ink-gray !important;
  font-size: 0.9em;
  font-style: italic;
  margin-top: 8px;
}

// ===============================================================
// 社交链接
// ===============================================================
.links-of-author {
  margin-top: 20px;

  .links-of-author-item {
    margin: 5px 0;

    a {
      display: flex;
      align-items: center;
      padding: 8px 12px;
      border-radius: 8px;
      background: rgba(139, 69, 19, 0.05);
      color: $ink-gray !important;
      transition: all 0.3s ease;

      &:hover {
        background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(59, 130, 246, 0.15) 100%);
        color: $purple-primary !important;
        transform: translateX(5px);
      }

      .fa, .fab, .fas {
        margin-right: 8px;
        color: $purple-primary;
      }
    }
  }
}

// ===============================================================
// 文章卡片 - 增强元信息展示
// ===============================================================
.post-block {
  background-color: $paper-yellow;
  border-radius: 12px;
  box-shadow: 0 3px 15px rgba(0,0,0,0.08);
  border: 1px solid rgba(139, 69, 19, 0.1);
  margin-bottom: 35px;
  padding: 40px;
  transition: all 0.3s ease;

  &:hover {
    box-shadow: 0 6px 25px rgba(0,0,0,0.12);
    transform: translateY(-3px);
  }
}

.post-header {
  margin-bottom: 20px;
}

.post-title {
  font-size: 1.9em;
  font-weight: 700;
  letter-spacing: 0.05em;
  margin-bottom: 15px;

  a {
    color: $ink-black;
    background: linear-gradient(to bottom, transparent 60%, rgba(139, 92, 246, 0.15) 60%);
    transition: all 0.3s ease;

    &:hover {
      color: $purple-primary;
      background: linear-gradient(to bottom, transparent 60%, rgba(139, 92, 246, 0.3) 60%);
    }
  }
}

// ===============================================================
// 文章元信息 - 增强版
// ===============================================================
.post-meta-container {
  margin-bottom: 20px;
  padding: 15px;
  background: rgba(139, 69, 19, 0.05);
  border-radius: 8px;
  border-left: 3px solid $purple-primary;
}

.post-meta {
  color: $ink-gray;
  font-size: 0.9em;
  display: flex;
  flex-wrap: wrap;
  gap: 15px;
  align-items: center;

  .post-meta-item {
    display: inline-flex;
    align-items: center;
    gap: 5px;

    i, .fa, .far, .fas {
      color: $purple-primary;
      margin-right: 4px;
    }

    a {
      color: $purple-primary;
      transition: color 0.3s ease;
      text-decoration: none;

      &:hover {
        color: $cinnabar-red;
        text-decoration: underline;
      }
    }

    time {
      border-bottom: 1px dashed $ink-gray;
      cursor: help;

      &:hover {
        border-bottom-style: solid;
        color: $purple-primary;
      }
    }
  }
}

// 发布日期样式
.post-meta-time {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(59, 130, 246, 0.1) 100%);
  padding: 4px 10px;
  border-radius: 15px;
  font-weight: 500;

  .fa-calendar {
    color: $purple-primary;
  }
}

// 分类标签样式
.post-meta-categories {
  .fa-folder {
    color: $purple-primary;
  }

  a {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(59, 130, 246, 0.15) 100%);
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 0.85em;
    margin: 0 3px;

    &:hover {
      background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
      color: white !important;
    }
  }
}

// 标签样式
.post-meta-tags {
  .fa-tags {
    color: $cinnabar-red;
  }

  a {
    background: rgba(201, 55, 44, 0.1);
    color: $cinnabar-red !important;
    padding: 3px 10px;
    border-radius: 12px;
    font-size: 0.85em;
    margin: 0 3px;

    &:hover {
      background: $cinnabar-red;
      color: white !important;
    }
  }
}

// 作者信息
.post-meta-author {
  .fa-user {
    color: $purple-primary;
  }
}

// 阅读时间
.post-meta-reading-time {
  .fa-clock {
    color: $purple-primary;
  }
}

// ===============================================================
// Archive Timeline Enhancements
// ===============================================================
.archive.posts-collapse {
  .post-block {
    padding: 30px 34px;
  }

  .post-content {
    margin-left: 44px;
  }

  .post-content::before {
    width: 3px;
    margin-left: -2px;
    background: linear-gradient(180deg, rgba(59, 130, 246, 0.25) 0%, rgba(30, 58, 138, 0.45) 100%);
  }

  .collection-title::before,
  .collection-year::before,
  .post-header::before {
    background: #3B82F6 !important;
    border-color: $paper-yellow !important;
  }

  .collection-year {
    margin: 36px 0 18px !important;
    color: $nav-deep-blue;
    font-size: 1.75em !important;
  }

  .post-content .post-header {
    display: block;
    margin: 16px 0;
    padding: 14px 18px 14px 20px;
    border: 1px solid rgba(59, 130, 246, 0.18);
    border-radius: 12px;
    background: rgba(245, 240, 225, 0.92);
  }

  .post-content .post-header:hover {
    border-color: rgba(30, 58, 138, 0.38);
    box-shadow: 0 6px 16px rgba(30, 58, 138, 0.08);
  }

  .post-content .post-meta-container {
    display: inline-flex;
    min-width: 68px;
    margin-right: 12px;
    padding: 4px 10px;
    border-radius: 8px;
    background: rgba(59, 130, 246, 0.1);
    color: $nav-deep-blue;
    font-weight: 600;
  }

  .post-content .post-title {
    display: inline;
    font-size: 1.34em;
    font-weight: 600;
  }

  .post-content .post-title a {
    color: $ink-black !important;
    background: linear-gradient(to bottom, transparent 66%, rgba(59, 130, 246, 0.16) 66%);
  }

  .archive-post-note {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 12px;
    margin-left: 82px;
  }

  .archive-note-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 0.82em;
    line-height: 1.5;
    color: $nav-deep-blue;
    border: 1px solid rgba(30, 58, 138, 0.2);
    background: rgba(219, 234, 254, 0.45);
    max-width: 100%;
  }

  .archive-note-item i {
    color: #1E40AF;
  }

  .archive-note-summary {
    border-color: rgba(139, 92, 246, 0.28);
    background: rgba(139, 92, 246, 0.1);
    color: $ink-gray;
  }
}

// ===============================================================
// 文章摘要
// ===============================================================
.post-excerpt {
  color: $ink-gray;
  line-height: 1.8;
  margin: 20px 0;

  p {
    margin: 0;
    text-indent: 2em;
  }
}

// ===============================================================
// 阅读全文按钮
// ===============================================================
.post-button {
  margin-top: 25px;

  .btn {
    background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
    color: white;
    border: none;
    border-radius: 25px;
    padding: 12px 35px;
    font-size: 0.95em;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
    font-weight: 500;
    box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);

    &:hover {
      background: linear-gradient(135deg, $purple-dark 0%, $blue-dark 100%);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(139, 92, 246, 0.4);
    }
  }
}

// ===============================================================
// 文章内容
// ===============================================================
.post-body {
  color: $ink-black;
  line-height: 1.9;
  font-size: 1.05em;
  text-align: justify;

  p {
    margin-bottom: 1.5em;
    text-indent: 2em;
  }

  blockquote {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.08) 0%, rgba(59, 130, 246, 0.08) 100%);
    border-left: 4px solid $purple-primary;
    padding: 20px 25px;
    margin: 25px 0;
    font-style: italic;
    color: $ink-gray;
    border-radius: 0 8px 8px 0;

    p {
      text-indent: 0;
      margin-bottom: 0;
    }
  }

  a {
    color: $purple-primary;
    border-bottom: 1px dashed $purple-primary;
    transition: all 0.3s ease;

    &:hover {
      color: $purple-dark;
      border-bottom-style: solid;
    }
  }

  img {
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    border: 8px solid $paper-yellow;
    background-color: $paper-yellow;
  }

  hr {
    border: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, $purple-primary, $blue-primary, transparent);
    margin: 2em 0;
  }

  table {
    border-collapse: collapse;
    width: 100%;
    margin: 1.5em 0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);

    th, td {
      border: 1px solid rgba(139, 69, 19, 0.3);
      padding: 12px 18px;
    }

    th {
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(59, 130, 246, 0.15) 100%);
      font-weight: 600;
    }

    tr:nth-child(even) {
      background-color: rgba(245, 240, 225, 0.5);
    }
  }
}

// ===============================================================
// 分页样式
// ===============================================================
.pagination {
  .page-number {
    background-color: $paper-yellow;
    border: 1px solid rgba(139, 69, 19, 0.2);
    color: $ink-gray;
    border-radius: 6px;
    padding: 8px 16px;
    transition: all 0.3s ease;

    &:hover {
      background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
      color: white;
      border-color: transparent;
      transform: translateY(-2px);
    }

    &.current {
      background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
      color: white;
      border-color: transparent;
      box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
    }
  }

  .prev, .next {
    background-color: $paper-yellow;
    border: 1px solid rgba(139, 69, 19, 0.2);
    color: $ink-gray;
    border-radius: 6px;
    padding: 8px 20px;
    transition: all 0.3s ease;

    &:hover {
      background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
      color: white;
      transform: translateY(-2px);
    }
  }
}

// ===============================================================
// 页脚
// ===============================================================
.footer {
  background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
  color: $paper-yellow;
  border-top: 3px solid $purple-primary;

  a {
    color: #A78BFA;

    &:hover {
      color: $cinnabar-red;
    }
  }
}

// ===============================================================
// 返回顶部
// ===============================================================
.back-to-top {
  background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
  color: white;
  border-radius: 50%;
  width: 50px;
  height: 50px;
  box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
  transition: all 0.3s ease;

  &:hover {
    background: linear-gradient(135deg, $purple-dark 0%, $blue-dark 100%);
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.4);
  }
}

// ===============================================================
// 标签云样式
// ===============================================================
.tag-cloud {
  text-align: center;

  .tag-cloud-tags {
    a {
      display: inline-block;
      margin: 6px;
      padding: 8px 18px;
      border-radius: 20px;
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(59, 130, 246, 0.1) 100%);
      border: 1px solid rgba(139, 92, 246, 0.2);
      color: $purple-primary;
      font-size: 0.9em;
      transition: all 0.3s ease;

      &:hover {
        background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
        color: white;
        border-color: transparent;
        transform: scale(1.1);
        box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
      }
    }
  }
}

// ===============================================================
// 分类页面
// ===============================================================
.category-all-page {
  .category-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    padding: 20px 0;
  }

  .category-list-item {
    background: linear-gradient(145deg, $paper-yellow 0%, #FFFEF9 100%);
    border-radius: 12px;
    padding: 25px;
    border-left: 5px solid $purple-primary;
    transition: all 0.3s ease;
    box-shadow: 0 3px 10px rgba(0,0,0,0.06);

    &:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.12);
      border-left-color: $blue-primary;
    }

    .category-list-count {
      color: $purple-primary;
      font-weight: 600;
    }
  }
}

// ===============================================================
// 代码块样式
// ===============================================================
code {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(59, 130, 246, 0.1) 100%);
  color: $purple-primary;
  padding: 3px 8px;
  border-radius: 4px;
  font-family: 'Noto Sans SC', 'Fira Code', monospace;
  font-size: 0.9em;
}

pre {
  background: linear-gradient(145deg, #f8f6f0 0%, #f0ece3 100%);
  border: 1px solid rgba(139, 69, 19, 0.2);
  border-radius: 8px;
  padding: 20px;
  overflow-x: auto;
  box-shadow: inset 0 2px 8px rgba(0,0,0,0.05);

  code {
    background-color: transparent;
    color: $ink-black;
    padding: 0;
  }
}

// ===============================================================
// 搜索框
// ===============================================================
.search-popup {
  background-color: $paper-yellow;
  border-radius: 12px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.2);

  .search-input {
    background-color: white;
    border: 2px solid rgba(139, 92, 246, 0.3);
    color: $ink-black;
    border-radius: 25px;
    padding: 12px 20px;
    font-size: 1em;

    &:focus {
      border-color: $purple-primary;
      box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1);
      outline: none;
    }
  }
}

// ===============================================================
// 选中文字样式
// ===============================================================
::selection {
  background-color: rgba(139, 92, 246, 0.2);
  color: $ink-black;
}

// ===============================================================
// 滚动条
// ===============================================================
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track {
  background-color: $old-paper;
  border-radius: 5px;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, rgba(139, 92, 246, 0.4) 0%, rgba(59, 130, 246, 0.6) 100%);
  border-radius: 5px;
  border: 2px solid $old-paper;

  &:hover {
    background: linear-gradient(180deg, rgba(139, 92, 246, 0.6) 0%, rgba(59, 130, 246, 0.8) 100%);
  }
}

// ===============================================================
// 响应式优化
// ===============================================================
@media (max-width: 768px) {
  .site-title {
    font-size: 1.6em;
    letter-spacing: 0.15em;
    padding: 6px 12px;
  }

  .site-subtitle {
    font-size: 0.8em;
  }

  .post-block {
    padding: 25px;
    margin-bottom: 25px;
  }

  .post-title {
    font-size: 1.5em;
  }

  .post-meta {
    flex-direction: column;
    gap: 8px;
  }
}
