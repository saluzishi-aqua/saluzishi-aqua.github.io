// ===============================================================
// 飒露紫石 - 紫蓝渐变风格样式
// 配色：紫色、蓝色渐变 + 宣纸黄
// ===============================================================

// 色彩定义
$purple-primary = #8B5CF6       // 主紫色
$purple-dark = #6D28D9          // 深紫
$blue-primary = #3B82F6         // 主蓝色
$blue-dark = #1E40AF            // 深蓝
$ink-black = #1F2937            // 墨黑
$paper-yellow = #F5F0E1         // 宣纸黄
$cinnabar-red = #C9372C         // 朱砂红
$ink-gray = #4B5563             // 灰色
$old-paper = #F9F7F2            // 古纸色

// 全局背景
body {
  background-color: $old-paper;
  font-family: 'Noto Serif SC', 'Source Han Serif SC', 'SimSun', 'STSong', serif;
}

// 标题字体
h1, h2, h3, h4, h5, h6 {
  font-family: 'Noto Serif SC', 'Source Han Serif SC', 'SimHei', serif;
  font-weight: 600;
  color: $ink-black;
}

// ===============================================================
// 头部导航 - 紫蓝渐变
// ===============================================================
.header {
  background: linear-gradient(135deg, #8B5CF6 0%, #3B82F6 50%, #06B6D4 100%);
  border-bottom: none;
  box-shadow: 0 4px 20px rgba(139, 92, 246, 0.3);
}

// 站点标题 - 飒露紫石
.site-title {
  font-size: 2.4em;
  font-weight: 700;
  letter-spacing: 0.3em;
  color: #FFFFFF !important;
  text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
  padding: 10px 25px;
  border: 2px solid rgba(255,255,255,0.3);
  border-radius: 12px;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10px);
  display: inline-block;
  transition: all 0.3s ease;

  &:hover {
    background: rgba(255,255,255,0.25);
    border-color: rgba(255,255,255,0.5);
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(0,0,0,0.2);
  }
}

// 站点副标题
.site-subtitle {
  font-size: 1em;
  color: rgba(255,255,255,0.9);
  letter-spacing: 0.15em;
  font-style: italic;
  margin-top: 8px;
  text-shadow: 1px 1px 2px rgba(0,0,0,0.2);
}

// Logo区域
.brand {
  background: transparent;
  padding: 15px 0;
}

// ===============================================================
// 菜单样式 - 适配渐变背景
// ===============================================================
.menu {
  .menu-item {
    a {
      color: rgba(255,255,255,0.9);
      font-size: 0.95em;
      letter-spacing: 0.05em;
      transition: all 0.3s ease;
      border-bottom: 3px solid transparent;
      padding: 8px 15px;
      font-weight: 500;

      &:hover {
        color: #FFFFFF;
        border-bottom-color: rgba(255,255,255,0.8);
        background-color: rgba(255,255,255,0.15);
        border-radius: 4px;
      }
    }

    &.menu-item-active a {
      color: #FFFFFF;
      border-bottom-color: #FFFFFF;
      font-weight: 600;
      background-color: rgba(255,255,255,0.2);
      border-radius: 4px;
    }
  }
}

// ===============================================================
// 侧边栏样式
// ===============================================================
.sidebar {
  background-color: rgba(247, 243, 233, 0.95);
  border-right: 1px solid rgba(139, 69, 19, 0.1);

  .sidebar-inner {
    background-color: transparent;
  }
}

// ===============================================================
// 紫色圆形头像样式
// ===============================================================
.site-author-image {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B5CF6 0%, #3B82F6 100%);
  border: 4px solid white;
  box-shadow:
    0 4px 15px rgba(139, 92, 246, 0.3),
    0 0 0 4px rgba(139, 92, 246, 0.1);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  overflow: hidden;

  &:hover {
    transform: scale(1.1) rotate(5deg);
    box-shadow:
      0 8px 25px rgba(139, 92, 246, 0.4),
      0 0 0 6px rgba(139, 92, 246, 0.2);
  }
}

.site-author {
  text-align: center;
  padding: 20px 0;
}

.site-author-name {
  color: $ink-black;
  font-weight: 600;
  letter-spacing: 0.15em;
  font-size: 1.2em;
  margin-top: 15px;
}

.site-description {
  color: $ink-gray;
  font-size: 0.9em;
  font-style: italic;
  margin-top: 8px;
}

// ===============================================================
// 文章卡片
// ===============================================================
.post-block {
  background-color: $paper-yellow;
  border-radius: 12px;
  box-shadow: 0 3px 15px rgba(0,0,0,0.08);
  border: 1px solid rgba(139, 69, 19, 0.1);
  margin-bottom: 35px;
  padding: 40px;
  transition: all 0.3s ease;
  position: relative;

  &:hover {
    box-shadow: 0 6px 25px rgba(0,0,0,0.12);
    transform: translateY(-3px);
  }
}

// 文章标题
.post-title {
  font-size: 1.9em;
  font-weight: 700;
  letter-spacing: 0.05em;
  margin-bottom: 15px;

  a {
    color: $ink-black;
    background: linear-gradient(to bottom, transparent 60%, rgba(139, 92, 246, 0.15) 60%);
    transition: all 0.3s ease;

    &:hover {
      color: $purple-primary;
      background: linear-gradient(to bottom, transparent 60%, rgba(139, 92, 246, 0.3) 60%);
    }
  }
}

// 文章元信息
.post-meta {
  color: $ink-gray;
  font-size: 0.85em;
  margin-bottom: 20px;
  padding-bottom: 15px;
  border-bottom: 1px dashed rgba(139, 69, 19, 0.2);

  .post-meta-item {
    margin-right: 15px;

    a {
      color: $purple-primary;
      transition: color 0.3s ease;

      &:hover {
        color: $cinnabar-red;
      }
    }
  }
}

// 分类标签展示
.post-categories, .post-tags {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 10px 0;

  a {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8em;
    transition: all 0.3s ease;
  }
}

.post-categories a {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(59, 130, 246, 0.15) 100%);
  color: $purple-primary;
  border: 1px solid rgba(139, 92, 246, 0.3);

  &:hover {
    background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
    color: white;
    transform: translateY(-2px);
  }
}

.post-tags a {
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.1) 0%, rgba(139, 69, 19, 0.2) 100%);
  color: $ink-gray;
  border: 1px solid rgba(139, 69, 19, 0.2);

  &:hover {
    background: $cinnabar-red;
    color: white;
    border-color: $cinnabar-red;
    transform: translateY(-2px);
  }
}

// ===============================================================
// 文章内容
// ===============================================================
.post-body {
  color: $ink-black;
  line-height: 1.9;
  font-size: 1.05em;
  text-align: justify;

  p {
    margin-bottom: 1.5em;
    text-indent: 2em;
  }

  blockquote {
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.08) 0%, rgba(59, 130, 246, 0.08) 100%);
    border-left: 4px solid $purple-primary;
    padding: 20px 25px;
    margin: 25px 0;
    font-style: italic;
    color: $ink-gray;
    border-radius: 0 8px 8px 0;

    p {
      text-indent: 0;
      margin-bottom: 0;
    }
  }

  a {
    color: $purple-primary;
    border-bottom: 1px dashed $purple-primary;
    transition: all 0.3s ease;

    &:hover {
      color: $purple-dark;
      border-bottom-style: solid;
    }
  }

  img {
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    border: 8px solid $paper-yellow;
    background-color: $paper-yellow;
  }

  hr {
    border: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, $purple-primary, $blue-primary, transparent);
    margin: 2em 0;
  }

  table {
    border-collapse: collapse;
    width: 100%;
    margin: 1.5em 0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);

    th, td {
      border: 1px solid rgba(139, 69, 19, 0.3);
      padding: 12px 18px;
    }

    th {
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(59, 130, 246, 0.15) 100%);
      font-weight: 600;
    }

    tr:nth-child(even) {
      background-color: rgba(245, 240, 225, 0.5);
    }
  }
}

// ===============================================================
// 阅读全文按钮
// ===============================================================
.post-button {
  .btn {
    background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
    color: white;
    border: none;
    border-radius: 25px;
    padding: 10px 30px;
    font-size: 0.95em;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
    font-weight: 500;

    &:hover {
      background: linear-gradient(135deg, $purple-dark 0%, $blue-dark 100%);
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(139, 92, 246, 0.4);
    }
  }
}

// ===============================================================
// 分页样式
// ===============================================================
.pagination {
  .page-number {
    background-color: $paper-yellow;
    border: 1px solid rgba(139, 69, 19, 0.2);
    color: $ink-gray;
    border-radius: 6px;
    padding: 8px 16px;
    transition: all 0.3s ease;

    &:hover {
      background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
      color: white;
      border-color: transparent;
      transform: translateY(-2px);
    }

    &.current {
      background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
      color: white;
      border-color: transparent;
      box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
    }
  }

  .prev, .next {
    background-color: $paper-yellow;
    border: 1px solid rgba(139, 69, 19, 0.2);
    color: $ink-gray;
    border-radius: 6px;
    padding: 8px 20px;
    transition: all 0.3s ease;

    &:hover {
      background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
      color: white;
      transform: translateY(-2px);
    }
  }
}

// ===============================================================
// 页脚
// ===============================================================
.footer {
  background: linear-gradient(135deg, #1F2937 0%, #111827 100%);
  color: $paper-yellow;
  border-top: 3px solid $purple-primary;

  a {
    color: #A78BFA;
    transition: color 0.3s ease;

    &:hover {
      color: $cinnabar-red;
    }
  }
}

// ===============================================================
// 返回顶部
// ===============================================================
.back-to-top {
  background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
  color: white;
  border-radius: 50%;
  width: 50px;
  height: 50px;
  box-shadow: 0 4px 15px rgba(139, 92, 246, 0.3);
  transition: all 0.3s ease;

  &:hover {
    background: linear-gradient(135deg, $purple-dark 0%, $blue-dark 100%);
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(139, 92, 246, 0.4);
  }
}

// ===============================================================
// 标签云样式
// ===============================================================
.tag-cloud {
  text-align: center;

  .tag-cloud-tags {
    a {
      display: inline-block;
      margin: 6px;
      padding: 8px 18px;
      border-radius: 20px;
      background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(59, 130, 246, 0.1) 100%);
      border: 1px solid rgba(139, 92, 246, 0.2);
      color: $purple-primary;
      font-size: 0.9em;
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);

      &:hover {
        background: linear-gradient(135deg, $purple-primary 0%, $blue-primary 100%);
        color: white;
        border-color: transparent;
        transform: scale(1.1);
        box-shadow: 0 4px 12px rgba(139, 92, 246, 0.3);
      }
    }
  }
}

// ===============================================================
// 分类页面
// ===============================================================
.category-all-page {
  .category-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    padding: 20px 0;
  }

  .category-list-item {
    background: linear-gradient(145deg, $paper-yellow 0%, #FFFEF9 100%);
    border-radius: 12px;
    padding: 25px;
    border-left: 5px solid $purple-primary;
    transition: all 0.3s ease;
    box-shadow: 0 3px 10px rgba(0,0,0,0.06);

    &:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.12);
      border-left-color: $blue-primary;
    }

    .category-list-count {
      color: $purple-primary;
      font-weight: 600;
    }
  }
}

// ===============================================================
// 侧边栏模块样式
// ===============================================================
.sidebar-panel {
  background: linear-gradient(145deg, rgba(255,255,255,0.6) 0%, rgba(245,240,225,0.6) 100%);
  border-radius: 10px;
  padding: 20px;
  margin-bottom: 20px;
  border: 1px solid rgba(139, 69, 19, 0.1);

  .sidebar-panel-title {
    font-size: 1.1em;
    font-weight: 600;
    color: $ink-black;
    border-bottom: 2px solid $purple-primary;
    padding-bottom: 10px;
    margin-bottom: 15px;
    letter-spacing: 0.1em;
  }
}

// ===============================================================
// 代码块样式
// ===============================================================
code {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(59, 130, 246, 0.1) 100%);
  color: $purple-primary;
  padding: 3px 8px;
  border-radius: 4px;
  font-family: 'Noto Sans SC', 'Fira Code', monospace;
  font-size: 0.9em;
}

pre {
  background: linear-gradient(145deg, #f8f6f0 0%, #f0ece3 100%);
  border: 1px solid rgba(139, 69, 19, 0.2);
  border-radius: 8px;
  padding: 20px;
  overflow-x: auto;
  box-shadow: inset 0 2px 8px rgba(0,0,0,0.05);

  code {
    background-color: transparent;
    color: $ink-black;
    padding: 0;
  }
}

// ===============================================================
// 搜索框
// ===============================================================
.search-popup {
  background-color: $paper-yellow;
  border-radius: 12px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.2);

  .search-input {
    background-color: white;
    border: 2px solid rgba(139, 92, 246, 0.3);
    color: $ink-black;
    border-radius: 25px;
    padding: 12px 20px;
    font-size: 1em;

    &:focus {
      border-color: $purple-primary;
      box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.1);
      outline: none;
    }
  }
}

// ===============================================================
// 选中文字样式
// ===============================================================
::selection {
  background-color: rgba(139, 92, 246, 0.2);
  color: $ink-black;
}

// ===============================================================
// 滚动条
// ===============================================================
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track {
  background-color: $old-paper;
  border-radius: 5px;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, rgba(139, 92, 246, 0.4) 0%, rgba(59, 130, 246, 0.6) 100%);
  border-radius: 5px;
  border: 2px solid $old-paper;

  &:hover {
    background: linear-gradient(180deg, rgba(139, 92, 246, 0.6) 0%, rgba(59, 130, 246, 0.8) 100%);
  }
}

// ===============================================================
// 响应式优化
// ===============================================================
@media (max-width: 768px) {
  .site-title {
    font-size: 1.6em;
    letter-spacing: 0.15em;
    padding: 6px 12px;
  }

  .site-subtitle {
    font-size: 0.8em;
  }

  .post-block {
    padding: 25px;
    margin-bottom: 25px;
  }

  .post-title {
    font-size: 1.5em;
  }
}