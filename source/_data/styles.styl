// ===============================================================
// 墨香轩 - 文人墨客风格样式（多元主题拓展版）
// 配色：宣纸黄、墨黑、朱砂红、紫韵
// ===============================================================

// 色彩定义 - 传统中国色
$ink-black = #2C2C2C           // 墨黑
$paper-yellow = #F5F0E1        // 宣纸黄
$cinnabar-red = #C9372C        // 朱砂红
$ink-gray = #5A5A5A            // 淡墨
$old-paper = #F7F3E9           // 古纸色
$bamboo-green = #7B8B6F        // 竹青
$gold = #B8860B                // 赭石
$purple = #8B5CF6              // 紫韵 - 头像主色
$purple-dark = #6D28D9         // 深紫
$header-bg = #F5F0E1           // 头部背景 - 浅色
$header-text = #2C2C2C         // 头部文字 - 深色

// 全局背景 - 宣纸纹理感
body {
  background-color: $old-paper;
  background-image: linear-gradient(
    to bottom,
    rgba(255,255,255,0.1) 0%,
    rgba(245,240,225,0.3) 100%
  );
  font-family: 'Noto Serif SC', 'Source Han Serif SC', 'SimSun', 'STSong', serif;
}

// 标题字体 - 书法感
h1, h2, h3, h4, h5, h6 {
  font-family: 'Noto Serif SC', 'Source Han Serif SC', 'SimHei', serif;
  font-weight: 600;
  color: $ink-black;
}

// ===============================================================
// 头部导航 - 优化可见性
// ===============================================================
.header {
  background: linear-gradient(135deg, #F5F0E1 0%, #EDE4D3 100%);
  border-bottom: 2px solid rgba(139, 69, 19, 0.15);
  box-shadow: 0 2px 15px rgba(0,0,0,0.08);
}

// 站点标题 - 高对比度设计
.site-title {
  font-size: 2.2em;
  font-weight: 700;
  letter-spacing: 0.25em;
  color: #1a1a1a;
  text-shadow:
    1px 1px 0px rgba(255,255,255,0.8),
    2px 2px 4px rgba(139, 69, 19, 0.2);
  padding: 8px 20px;
  border: 2px solid rgba(139, 69, 19, 0.3);
  border-radius: 8px;
  background: linear-gradient(145deg, #FFFEF9 0%, #F5F0E1 100%);
  display: inline-block;
  transition: all 0.3s ease;

  &:hover {
    color: $cinnabar-red;
    border-color: $cinnabar-red;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(201, 55, 44, 0.2);
  }
}

// 站点副标题
.site-subtitle {
  font-size: 0.95em;
  color: #4a4a4a;
  letter-spacing: 0.2em;
  font-style: italic;
  margin-top: 8px;
  text-shadow: 1px 1px 2px rgba(255,255,255,0.8);
}

// ===============================================================
// Logo区域样式
// ===============================================================
.brand {
  background: transparent;
  padding: 15px 0;

  .site-title {
    color: #1a1a1a !important;
  }
}

// ===============================================================
// 侧边栏样式
// ===============================================================
.sidebar {
  background-color: rgba(247, 243, 233, 0.95);
  border-right: 1px solid rgba(139, 69, 19, 0.1);

  .sidebar-inner {
    background-color: transparent;
  }
}

// ===============================================================
// 紫色圆形头像样式
// ===============================================================
.site-author-image {
  width: 120px;
  height: 120px;
  border-radius: 50%;
  background: linear-gradient(135deg, $purple 0%, $purple-dark 100%);
  border: 4px solid white;
  box-shadow:
    0 4px 15px rgba(139, 69, 19, 0.2),
    0 0 0 4px rgba(139, 69, 19, 0.1);
  transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  overflow: hidden;

  &:hover {
    transform: scale(1.1) rotate(5deg);
    box-shadow:
      0 8px 25px rgba(139, 69, 19, 0.3),
      0 0 0 6px rgba(139, 69, 19, 0.15);
  }
}

// 头像区域整体样式
.site-author {
  text-align: center;
  padding: 20px 0;
}

.site-author-name {
  color: $ink-black;
  font-weight: 600;
  letter-spacing: 0.15em;
  font-size: 1.2em;
  margin-top: 15px;
}

.site-description {
  color: $ink-gray;
  font-size: 0.9em;
  font-style: italic;
  margin-top: 8px;
}

// ===============================================================
// 菜单样式 - 优化高亮效果
// ===============================================================
.menu {
  .menu-item {
    a {
      color: #3a3a3a;
      font-size: 0.95em;
      letter-spacing: 0.05em;
      transition: all 0.3s ease;
      border-bottom: 3px solid transparent;
      padding: 8px 15px;
      font-weight: 500;

      &:hover {
        color: $cinnabar-red;
        border-bottom-color: $cinnabar-red;
        background-color: rgba(201, 55, 44, 0.05);
        border-radius: 4px;
      }
    }

    &.menu-item-active a {
      color: $cinnabar-red;
      border-bottom-color: $cinnabar-red;
      font-weight: 600;
      background-color: rgba(201, 55, 44, 0.08);
      border-radius: 4px;
    }
  }
}

// ===============================================================
// 文章卡片 - 增加tag和category显示
// ===============================================================
.post-block {
  background-color: $paper-yellow;
  border-radius: 12px;
  box-shadow: 0 3px 15px rgba(0,0,0,0.08);
  border: 1px solid rgba(139, 69, 19, 0.1);
  margin-bottom: 35px;
  padding: 40px;
  transition: all 0.3s ease;
  position: relative;

  &:hover {
    box-shadow: 0 6px 25px rgba(0,0,0,0.12);
    transform: translateY(-3px);
  }
}

// 文章标题
.post-title {
  font-size: 1.9em;
  font-weight: 700;
  letter-spacing: 0.05em;
  margin-bottom: 15px;

  a {
    color: $ink-black;
    background: linear-gradient(to bottom, transparent 60%, rgba(201, 55, 44, 0.15) 60%);
    transition: all 0.3s ease;

    &:hover {
      color: $cinnabar-red;
      background: linear-gradient(to bottom, transparent 60%, rgba(201, 55, 44, 0.3) 60%);
    }
  }
}

// 文章元信息 - 增加标签和分类显示
.post-meta {
  color: $ink-gray;
  font-size: 0.85em;
  margin-bottom: 20px;
  padding-bottom: 15px;
  border-bottom: 1px dashed rgba(139, 69, 19, 0.2);

  .post-meta-item-icon {
    color: $bamboo-green;
  }

  // 分类标签样式
  .post-meta-item {
    margin-right: 15px;

    a {
      color: $bamboo-green;
      transition: color 0.3s ease;

      &:hover {
        color: $cinnabar-red;
      }
    }
  }
}

// 分类标签展示
.post-categories, .post-tags {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 8px;
  margin: 10px 0;

  a {
    display: inline-block;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 0.8em;
    transition: all 0.3s ease;
  }
}

.post-categories a {
  background: linear-gradient(135deg, rgba(184, 134, 11, 0.15) 0%, rgba(184, 134, 11, 0.25) 100%);
  color: $gold;
  border: 1px solid rgba(184, 134, 11, 0.3);

  &:hover {
    background: $gold;
    color: white;
    transform: translateY(-2px);
  }
}

.post-tags a {
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.1) 0%, rgba(139, 69, 19, 0.2) 100%);
  color: $ink-gray;
  border: 1px solid rgba(139, 69, 19, 0.2);

  &:hover {
    background: $cinnabar-red;
    color: white;
    border-color: $cinnabar-red;
    transform: translateY(-2px);
  }
}

// 摘要内容
.post-excerpt {
  color: $ink-gray;
  line-height: 1.8;
  margin: 20px 0;

  p {
    margin: 0;
    text-indent: 2em;
  }
}

// ===============================================================
// 文章内容
// ===============================================================
.post-body {
  color: $ink-black;
  line-height: 1.9;
  font-size: 1.05em;
  text-align: justify;

  p {
    margin-bottom: 1.5em;
    text-indent: 2em;
  }

  // 引用块 - 古籍引用样式
  blockquote {
    background-color: rgba(184, 134, 11, 0.1);
    border-left: 4px solid $cinnabar-red;
    padding: 20px 25px;
    margin: 25px 0;
    font-style: italic;
    color: $ink-gray;
    border-radius: 0 8px 8px 0;

    p {
      text-indent: 0;
      margin-bottom: 0;
    }
  }

  // 链接样式
  a {
    color: $cinnabar-red;
    border-bottom: 1px dashed $cinnabar-red;
    transition: all 0.3s ease;

    &:hover {
      color: darken($cinnabar-red, 15%);
      border-bottom-style: solid;
    }
  }

  // 图片样式 - 画卷感
  img {
    border-radius: 8px;
    box-shadow: 0 4px 15px rgba(0,0,0,0.15);
    border: 8px solid $paper-yellow;
    background-color: $paper-yellow;
  }

  // 水平线 - 水墨分隔
  hr {
    border: 0;
    height: 2px;
    background: linear-gradient(to right, transparent, $ink-gray, transparent);
    margin: 2em 0;
  }

  // 表格样式
  table {
    border-collapse: collapse;
    width: 100%;
    margin: 1.5em 0;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);

    th, td {
      border: 1px solid rgba(139, 69, 19, 0.3);
      padding: 12px 18px;
    }

    th {
      background-color: rgba(184, 134, 11, 0.15);
      font-weight: 600;
    }

    tr:nth-child(even) {
      background-color: rgba(245, 240, 225, 0.5);
    }
  }

  // 列表样式优化
  ul, ol {
    margin: 1em 0;
    padding-left: 2em;

    li {
      margin: 8px 0;
      line-height: 1.8;
    }
  }
}

// ===============================================================
// 阅读全文按钮
// ===============================================================
.post-button {
  .btn {
    background-color: transparent;
    color: $cinnabar-red;
    border: 2px solid $cinnabar-red;
    border-radius: 25px;
    padding: 10px 30px;
    font-size: 0.95em;
    letter-spacing: 0.1em;
    transition: all 0.3s ease;
    font-weight: 500;

    &:hover {
      background-color: $cinnabar-red;
      color: white;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(201, 55, 44, 0.3);
    }
  }
}

// ===============================================================
// 分页样式
// ===============================================================
.pagination {
  .page-number {
    background-color: $paper-yellow;
    border: 1px solid rgba(139, 69, 19, 0.2);
    color: $ink-gray;
    border-radius: 6px;
    padding: 8px 16px;
    transition: all 0.3s ease;

    &:hover {
      background-color: $cinnabar-red;
      color: white;
      border-color: $cinnabar-red;
      transform: translateY(-2px);
    }

    &.current {
      background-color: $cinnabar-red;
      color: white;
      border-color: $cinnabar-red;
      box-shadow: 0 4px 12px rgba(201, 55, 44, 0.3);
    }
  }

  .prev, .next {
    background-color: $paper-yellow;
    border: 1px solid rgba(139, 69, 19, 0.2);
    color: $ink-gray;
    border-radius: 6px;
    padding: 8px 20px;
    transition: all 0.3s ease;

    &:hover {
      background-color: $cinnabar-red;
      color: white;
      transform: translateY(-2px);
    }
  }
}

// ===============================================================
// 页脚
// ===============================================================
.footer {
  background: linear-gradient(135deg, #2C2C2C 0%, #3a3a3a 100%);
  color: $paper-yellow;
  border-top: 3px solid $cinnabar-red;

  a {
    color: $gold;
    transition: color 0.3s ease;

    &:hover {
      color: $cinnabar-red;
    }
  }
}

// ===============================================================
// 返回顶部
// ===============================================================
.back-to-top {
  background: linear-gradient(135deg, $cinnabar-red 0%, #a83028 100%);
  color: white;
  border-radius: 50%;
  width: 50px;
  height: 50px;
  box-shadow: 0 4px 15px rgba(201, 55, 44, 0.3);
  transition: all 0.3s ease;

  &:hover {
    background: linear-gradient(135deg, #a83028 0%, #8B2620 100%);
    transform: translateY(-3px);
    box-shadow: 0 6px 20px rgba(201, 55, 44, 0.4);
  }
}

// ===============================================================
// 标签云样式 - 丰富显示
// ===============================================================
.tag-cloud {
  text-align: center;

  .tag-cloud-tags {
    a {
      display: inline-block;
      margin: 6px;
      padding: 6px 16px;
      border-radius: 20px;
      background-color: $paper-yellow;
      border: 1px solid rgba(139, 69, 19, 0.2);
      color: $ink-gray;
      font-size: 0.9em;
      transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);

      &:hover {
        background-color: $cinnabar-red;
        color: white;
        border-color: $cinnabar-red;
        transform: scale(1.1);
        box-shadow: 0 4px 12px rgba(201, 55, 44, 0.3);
      }
    }
  }
}

// ===============================================================
// 分类页面 - 卡片式布局
// ===============================================================
.category-all-page {
  .category-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 20px;
    padding: 20px 0;
  }

  .category-list-item {
    background: linear-gradient(145deg, $paper-yellow 0%, #FFFEF9 100%);
    border-radius: 12px;
    padding: 25px;
    border-left: 5px solid $bamboo-green;
    transition: all 0.3s ease;
    box-shadow: 0 3px 10px rgba(0,0,0,0.06);

    &:hover {
      transform: translateY(-5px);
      box-shadow: 0 8px 25px rgba(0,0,0,0.12);
      border-left-color: $cinnabar-red;
    }

    .category-list-count {
      color: $cinnabar-red;
      font-weight: 600;
    }
  }
}

// ===============================================================
// 侧边栏模块样式
// ===============================================================
.sidebar-panel {
  background: linear-gradient(145deg, rgba(255,255,255,0.6) 0%, rgba(245,240,225,0.6) 100%);
  border-radius: 10px;
  padding: 20px;
  margin-bottom: 20px;
  border: 1px solid rgba(139, 69, 19, 0.1);

  .sidebar-panel-title {
    font-size: 1.1em;
    font-weight: 600;
    color: $ink-black;
    border-bottom: 2px solid $cinnabar-red;
    padding-bottom: 10px;
    margin-bottom: 15px;
    letter-spacing: 0.1em;
  }
}

// ===============================================================
// 代码块样式
// ===============================================================
code {
  background-color: rgba(184, 134, 11, 0.1);
  color: $cinnabar-red;
  padding: 3px 8px;
  border-radius: 4px;
  font-family: 'Noto Sans SC', 'Fira Code', monospace;
  font-size: 0.9em;
}

pre {
  background: linear-gradient(145deg, #f8f6f0 0%, #f0ece3 100%);
  border: 1px solid rgba(139, 69, 19, 0.2);
  border-radius: 8px;
  padding: 20px;
  overflow-x: auto;
  box-shadow: inset 0 2px 8px rgba(0,0,0,0.05);

  code {
    background-color: transparent;
    color: $ink-black;
    padding: 0;
  }
}

// ===============================================================
// 搜索框
// ===============================================================
.search-popup {
  background-color: $paper-yellow;
  border-radius: 12px;
  box-shadow: 0 10px 40px rgba(0,0,0,0.2);

  .search-input {
    background-color: white;
    border: 2px solid rgba(139, 69, 19, 0.3);
    color: $ink-black;
    border-radius: 25px;
    padding: 12px 20px;
    font-size: 1em;

    &:focus {
      border-color: $cinnabar-red;
      box-shadow: 0 0 0 4px rgba(201, 55, 44, 0.1);
      outline: none;
    }
  }
}

// ===============================================================
// 选中文字样式
// ===============================================================
::selection {
  background-color: rgba(201, 55, 44, 0.2);
  color: $ink-black;
}

// ===============================================================
// 滚动条
// ===============================================================
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track {
  background-color: $old-paper;
  border-radius: 5px;
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, rgba(139, 69, 19, 0.4) 0%, rgba(139, 69, 19, 0.6) 100%);
  border-radius: 5px;
  border: 2px solid $old-paper;

  &:hover {
    background: linear-gradient(180deg, rgba(139, 69, 19, 0.6) 0%, rgba(139, 69, 19, 0.8) 100%);
  }
}

// ===============================================================
// 公告栏样式
// ===============================================================
.sidebar-notice {
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.1) 0%, rgba(184, 134, 11, 0.1) 100%);
  border: 1px dashed rgba(139, 69, 19, 0.3);
  border-radius: 8px;
  padding: 15px;
  margin-bottom: 20px;

  .notice-title {
    color: $cinnabar-red;
    font-weight: 600;
    margin-bottom: 10px;
    font-size: 1em;
  }

  .notice-content {
    color: $ink-gray;
    font-size: 0.9em;
    line-height: 1.7;
  }
}

// ===============================================================
// 归档页面样式
// ===============================================================
.archive-list {
  .archive-list-item {
    padding: 15px 20px;
    margin: 10px 0;
    background: linear-gradient(145deg, $paper-yellow 0%, #FFFEF9 100%);
    border-radius: 8px;
    border-left: 4px solid $gold;
    transition: all 0.3s ease;

    &:hover {
      border-left-color: $cinnabar-red;
      transform: translateX(5px);
      box-shadow: 0 4px 15px rgba(0,0,0,0.08);
    }
  }
}

// ===============================================================
// 响应式优化
// ===============================================================
@media (max-width: 768px) {
  .site-title {
    font-size: 1.6em;
    letter-spacing: 0.15em;
    padding: 6px 12px;
  }

  .site-subtitle {
    font-size: 0.8em;
  }

  .post-block {
    padding: 25px;
    margin-bottom: 25px;
  }

  .post-title {
    font-size: 1.5em;
  }
}
